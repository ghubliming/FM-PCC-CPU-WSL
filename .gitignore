# The specific folder you want to ignore
dpcc/d3il_old
dpcc/d3il/environments/dataset/

# Security: Never track your license
gurobi.lic
*.lic

# Windows/WSL Metadata
*.Identifier
MUJOCO_LOG.TXT

# Runtime/Local Cache
.ipynb_checkpoints/
wandb/
__pycache__/

# Logs: ignore everything by default (no trailing slash = negation can override)
dpcc/logs

# Exception: track the plans subfolder only
!dpcc/logs/avoiding-d3il/
!dpcc/logs/avoiding-d3il/plans/
!dpcc/logs/avoiding-d3il/plans/**
